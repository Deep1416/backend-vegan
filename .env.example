PORT=4000
# Local: run Postgres and migrate. Remote (Neon): project must be active; URL must be reachable from your machine.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/veganfit?schema=public

# JWT for REST auth
JWT_SECRET=replace-with-long-random-secret

# Cloudinary (signed uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER_POSTS=veganfit/posts
CLOUDINARY_FOLDER_PROFILES=veganfit/profiles

# Email OTP (SMTP / Nodemailer)
AUTH_FROM_EMAIL=VeganFit <your-email@gmail.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Google login (optional)
GOOGLE_CLIENT_ID=replace-with-google-client-id

# Temporary dev auth (fallback): pass X-User-Id header to act as a user
# X_USER_ID=your-user-id

# Prisma seed: demo gym trainer login + GymTrainer.linkedUserId (DM + /trainer queue)
# Set VEGANFIT_SKIP_TRAINER_LINK=true in production if you assign trainers manually.
# VEGANFIT_SKIP_TRAINER_LINK=false
# VEGANFIT_SEED_TRAINER_EMAIL=trainer@veganfit.dev
# VEGANFIT_SEED_TRAINER_PASSWORD=ChangeMeTrainer!24
