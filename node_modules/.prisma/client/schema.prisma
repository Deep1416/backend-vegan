generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Goal {
  FAT_LOSS
  MUSCLE_BUILD
  LIFESTYLE
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  ATHLETE
}

enum Gender {
  FEMALE
  MALE
  OTHER
}

enum RecipeCategory {
  FAT_LOSS
  MUSCLE_BUILD
  LIFESTYLE
}

enum WorkoutType {
  HOME
  GYM
}

enum OtpPurpose {
  SIGNUP
  LOGIN
  RESET
}

enum PostType {
  QUESTION
  WIN
  MEAL_IDEA
  NEED_SUPPORT
}

enum UserRole {
  MEMBER
  GYM_TRAINER
  ADMIN
}

enum PlanChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                      String         @id @default(cuid())
  name                    String?
  email                   String?        @unique
  emailVerified           DateTime?
  image                   String?
  passwordHash            String?
  heightCm                Float?
  weightKg                Float?
  age                     Int?
  gender                  Gender?
  activityLevel           ActivityLevel?
  goal                    Goal?
  calorieTargetOverride   Int?
  proteinTargetOverride   Int?
  hydrationTargetOverride Float?
  goalLocked              Boolean        @default(false)
  onboardingDone          Boolean        @default(false)
  streakCount             Int            @default(0)
  role                    UserRole       @default(MEMBER)
  gymTrainerId            String?
  approvedGymPlanJson     String?        @db.Text
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  accounts             Account[]
  sessions             Session[]
  trackers             Tracker[]
  workoutLogs          WorkoutLog[]
  streaks              Streak[]
  cheatMeals           CheatMeal[]
  posts                Post[]
  comments             Comment[]
  savedRecipes         SavedRecipe[]
  likes                PostLike[]
  following            Follow[]                   @relation("Following")
  followers            Follow[]                   @relation("Followers")
  dmConversationsA     Conversation[]             @relation("ConversationUserA")
  dmConversationsB     Conversation[]             @relation("ConversationUserB")
  dmMessages           Message[]
  dmReads              ConversationRead[]
  gymTrainer           GymTrainer?                @relation("AssignedTrainer", fields: [gymTrainerId], references: [id], onDelete: SetNull)
  trainerProfile       GymTrainer?                @relation("TrainerLinkedAccount")
  workoutPlanRequests  WorkoutPlanChangeRequest[] @relation("MemberPlanRequests")
  reviewedPlanRequests WorkoutPlanChangeRequest[] @relation("PlanReviewedBy")
  gymProgressPhotos    GymProgressPhoto[]
  missedWorkoutReports MissedWorkoutReport[]
}

model GymTrainer {
  id                   String                     @id @default(cuid())
  name                 String
  title                String?
  bio                  String?
  imageUrl             String?
  sortOrder            Int                        @default(0)
  linkedUserId         String?                    @unique
  linkedUser           User?                      @relation("TrainerLinkedAccount", fields: [linkedUserId], references: [id], onDelete: SetNull)
  assignedUsers        User[]                     @relation("AssignedTrainer")
  planRequests         WorkoutPlanChangeRequest[]
  missedWorkoutReports MissedWorkoutReport[]

  @@index([sortOrder])
}

model GymProgressPhoto {
  id        String   @id @default(cuid())
  userId    String
  imageUrl  String
  caption   String?  @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model MissedWorkoutReport {
  id           String   @id @default(cuid())
  userId       String
  gymTrainerId String
  reason       String   @db.Text
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymTrainer GymTrainer @relation(fields: [gymTrainerId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([gymTrainerId, createdAt])
}

model WorkoutPlanChangeRequest {
  id                   String           @id @default(cuid())
  userId               String
  gymTrainerId         String
  status               PlanChangeStatus @default(PENDING)
  memberNote           String?
  proposedSessionsJson String           @db.Text
  trainerComment       String?
  reviewedAt           DateTime?
  reviewedByUserId     String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user       User       @relation("MemberPlanRequests", fields: [userId], references: [id], onDelete: Cascade)
  gymTrainer GymTrainer @relation(fields: [gymTrainerId], references: [id], onDelete: Cascade)
  reviewedBy User?      @relation("PlanReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([gymTrainerId, status])
}

model OtpChallenge {
  id           String     @id @default(cuid())
  email        String
  purpose      OtpPurpose
  codeHash     String
  name         String?
  passwordHash String?
  attempts     Int        @default(0)
  consumedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime   @default(now())

  @@index([email, purpose, expiresAt])
}

model Recipe {
  id          String         @id @default(cuid())
  name        String
  image       String
  category    RecipeCategory
  description String
  ingredients String[]
  steps       String[]
  calories    Int
  protein     Int
  carbs       Int
  fats        Int
  isCheatMeal Boolean        @default(false)
  createdAt   DateTime       @default(now())

  savedBy         SavedRecipe[]
  cheatSelections CheatMeal[]
}

model Tracker {
  id               String   @id @default(cuid())
  userId           String
  date             DateTime @default(now())
  weightKg         Float?
  caloriesConsumed Int?
  proteinIntake    Int?
  workoutCompleted Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Streak {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  completed Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model CheatMeal {
  id         String   @id @default(cuid())
  userId     String
  recipeId   String
  weekStart  DateTime
  selectedAt DateTime @default(now())
  expiresAt  DateTime
  consumed   Boolean  @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([userId, weekStart])
}

model Post {
  id                String   @id @default(cuid())
  userId            String
  content           String
  recipeLink        String?
  type              PostType @default(QUESTION)
  imageUrl          String?
  acceptedCommentId String?
  createdAt         DateTime @default(now())

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    PostLike[]
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model SavedRecipe {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Conversation {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userA    User               @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User               @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]
  reads    ConversationRead[]

  @@unique([userAId, userBId])
  @@index([userAId, updatedAt])
  @@index([userBId, updatedAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model ConversationRead {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, updatedAt])
}

model Workout {
  id          String      @id @default(cuid())
  title       String
  description String
  type        WorkoutType
  goal        Goal
  durationMin Int
  level       String
}

model WorkoutLog {
  id          String   @id @default(cuid())
  userId      String
  performedAt DateTime @default(now())
  exercise    String
  sets        Int
  reps        Int
  weightKg    Float
  notes       String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, performedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
